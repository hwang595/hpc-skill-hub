{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hpc-skill-hub.org/schemas/benchmark.schema.json",
  "title": "HPC Skill Hub Benchmark Case",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "status",
    "mode",
    "risk_level",
    "skill_ids",
    "summary",
    "fixtures",
    "commands",
    "checks",
    "expected_outcomes"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 3
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "reviewed", "deprecated"]
    },
    "mode": {
      "type": "string",
      "enum": ["fixture", "static", "dry-run", "site"]
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "skill_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "summary": {
      "type": "string",
      "minLength": 12
    },
    "fixtures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "description"],
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "argv"],
        "additionalProperties": false,
        "properties": {
          "label": {
            "type": "string"
          },
          "argv": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "expect_returncode": {
            "type": "integer"
          },
          "requires_env": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Z][A-Z0-9_]*$"
            },
            "uniqueItems": true
          },
          "timeout_seconds": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "type", "path"],
        "additionalProperties": false,
        "properties": {
          "label": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["file_exists", "contains_all", "contains_any", "not_contains"]
          },
          "path": {
            "type": "string"
          },
          "patterns": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "expected_outcomes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}
