{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hpc-skill-hub.org/schemas/skill.schema.json",
  "title": "HPC Skill Manifest",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "status",
    "summary",
    "description",
    "categories",
    "tags",
    "maintainers",
    "license",
    "maturity",
    "risk_level",
    "tools",
    "inputs",
    "outputs",
    "artifacts",
    "examples",
    "tests",
    "references"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 3
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "reviewed", "deprecated"]
    },
    "summary": {
      "type": "string",
      "minLength": 12
    },
    "description": {
      "type": "string",
      "minLength": 24
    },
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "scheduler",
          "containers",
          "software",
          "workflow",
          "data",
          "debugging",
          "performance",
          "gpu",
          "mpi",
          "interactive",
          "admin",
          "education"
        ]
      },
      "uniqueItems": true
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9.+_-]*$"
      },
      "uniqueItems": true
    },
    "maintainers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string"
          },
          "contact": {
            "type": "string"
          }
        }
      }
    },
    "license": {
      "type": "string"
    },
    "maturity": {
      "type": "string",
      "enum": ["seed", "reviewed", "field-tested", "maintained"]
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "schedulers": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "required"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/io_item"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/io_item"
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "examples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title", "path"],
        "additionalProperties": false,
        "properties": {
          "title": {
            "type": "string"
          },
          "path": {
            "type": "string"
          }
        }
      }
    },
    "tests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type", "description"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "enum": ["static", "dry-run", "manual", "integration"]
          },
          "command": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "url"],
        "additionalProperties": false,
        "properties": {
          "title": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    }
  },
  "$defs": {
    "io_item": {
      "type": "object",
      "required": ["name", "description"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_.-]+$"
        },
        "type": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        }
      }
    }
  }
}
