{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hpc-skill-hub.org/schemas/skill-security-policy.schema.json",
  "title": "HPC Skill Hub Security Policy Pack",
  "type": "object",
  "required": [
    "$schema",
    "schema_version",
    "id",
    "version",
    "description",
    "extends",
    "enforcement",
    "rules",
    "severity_overrides",
    "exceptions"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "const": "https://hpc-skill-hub.org/schemas/skill-security-policy.schema.json"
    },
    "schema_version": {"const": "0.1.0"},
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "description": {"type": "string", "minLength": 1},
    "extends": {
      "oneOf": [
        {"type": "null"},
        {"const": "community-default@0.1.0"}
      ]
    },
    "enforcement": {
      "type": "object",
      "required": ["fail_on", "exception_max_severity"],
      "additionalProperties": false,
      "properties": {
        "fail_on": {"enum": ["low", "medium", "high", "critical"]},
        "exception_max_severity": {"enum": ["low", "medium"]}
      }
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "enabled"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*(?:\\.[a-z][a-z0-9-]*)+$"},
          "enabled": {"const": true}
        }
      }
    },
    "severity_overrides": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rule_id", "severity"],
        "additionalProperties": false,
        "properties": {
          "rule_id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*(?:\\.[a-z][a-z0-9-]*)+$"},
          "severity": {"enum": ["low", "medium", "high", "critical"]}
        }
      }
    },
    "exceptions": {
      "type": "array",
      "items": {"$ref": "#/$defs/reviewedException"}
    }
  },
  "$defs": {
    "reviewedException": {
      "type": "object",
      "required": [
        "id",
        "status",
        "rule_id",
        "skill_id",
        "path",
        "finding_digest",
        "reviewer",
        "reviewed_on",
        "expires_on",
        "justification"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
        "status": {"const": "accepted"},
        "rule_id": {"type": "string"},
        "skill_id": {"type": ["string", "null"]},
        "path": {"type": "string", "minLength": 1},
        "finding_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "reviewer": {"type": "string", "minLength": 1},
        "reviewed_on": {"type": "string", "format": "date"},
        "expires_on": {"type": "string", "format": "date"},
        "justification": {"type": "string", "minLength": 1}
      }
    }
  }
}
