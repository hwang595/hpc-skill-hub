{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hpc-skill-hub.org/schemas/community-skill-independent-review.schema.json",
  "title": "HPC Skill Hub Community Independent Review",
  "type": "object",
  "required": [
    "$schema",
    "schema_version",
    "review_id",
    "contribution",
    "scope",
    "reviewer_id",
    "reviewed_on",
    "domain",
    "decision",
    "independence_attestation",
    "conflict_disclosure",
    "evidence_url",
    "checklist",
    "bindings",
    "notes",
    "review_digest"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {"const": "https://hpc-skill-hub.org/schemas/community-skill-independent-review.schema.json"},
    "schema_version": {"const": "0.1.0"},
    "review_id": {"$ref": "#/$defs/publicId"},
    "contribution": {"$ref": "#/$defs/contribution"},
    "scope": {"enum": ["domain", "safety"]},
    "reviewer_id": {"$ref": "#/$defs/publicId"},
    "reviewed_on": {"type": "string", "format": "date"},
    "domain": {"$ref": "#/$defs/id"},
    "decision": {"enum": ["approved", "changes-requested", "rejected"]},
    "independence_attestation": {"const": true},
    "conflict_disclosure": {"type": "string", "minLength": 1, "maxLength": 500},
    "evidence_url": {"$ref": "#/$defs/httpsUrl"},
    "checklist": {
      "type": "object",
      "required": ["source_digest_verified", "scope_and_assumptions_reviewed", "examples_and_side_effects_reviewed", "risk_and_site_boundaries_reviewed", "references_reviewed", "public_safe_evidence_attested"],
      "additionalProperties": false,
      "properties": {
        "source_digest_verified": {"type": "boolean"},
        "scope_and_assumptions_reviewed": {"type": "boolean"},
        "examples_and_side_effects_reviewed": {"type": "boolean"},
        "risk_and_site_boundaries_reviewed": {"type": "boolean"},
        "references_reviewed": {"type": "boolean"},
        "public_safe_evidence_attested": {"type": "boolean"}
      }
    },
    "bindings": {"$ref": "#/$defs/bindings"},
    "notes": {"type": "string", "minLength": 1, "maxLength": 1000},
    "review_digest": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "publicId": {"type": "string", "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9._-]{0,62}[A-Za-z0-9])?$"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "httpsUrl": {"type": "string", "format": "uri", "pattern": "^https://"},
    "contribution": {
      "type": "object",
      "required": ["id", "version"],
      "additionalProperties": false,
      "properties": {"id": {"$ref": "#/$defs/id"}, "version": {"$ref": "#/$defs/version"}}
    },
    "bindings": {
      "type": "object",
      "required": ["packet_digest", "receipt_digest", "source_digest", "inventory_digest", "context_digest", "contribution_record_digest", "review_basis_digest"],
      "additionalProperties": false,
      "properties": {
        "packet_digest": {"$ref": "#/$defs/sha256"},
        "receipt_digest": {"$ref": "#/$defs/sha256"},
        "source_digest": {"$ref": "#/$defs/sha256"},
        "inventory_digest": {"$ref": "#/$defs/sha256"},
        "context_digest": {"$ref": "#/$defs/sha256"},
        "contribution_record_digest": {"$ref": "#/$defs/sha256"},
        "review_basis_digest": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}
