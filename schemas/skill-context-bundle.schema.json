{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hpc-skill-hub.org/schemas/skill-context-bundle.schema.json",
  "title": "HPC Skill Hub Verified Context Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "generated_by",
    "source_index",
    "limits",
    "skill_count",
    "file_count",
    "total_bytes",
    "skills",
    "digest"
  ],
  "properties": {
    "$schema": { "const": "../schemas/skill-context-bundle.schema.json" },
    "schema_version": { "const": "0.2.0" },
    "generated_by": { "const": "tools/build_skill_context.py" },
    "source_index": { "$ref": "#/$defs/sourceIndex" },
    "limits": { "$ref": "#/$defs/limits" },
    "skill_count": { "type": "integer", "minimum": 0 },
    "file_count": { "type": "integer", "minimum": 0 },
    "total_bytes": { "type": "integer", "minimum": 0 },
    "skills": {
      "type": "array",
      "items": { "$ref": "#/$defs/skill" }
    },
    "digest": { "$ref": "#/$defs/digest" }
  },
  "$defs": {
    "digest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "value"],
      "properties": {
        "algorithm": { "const": "sha256" },
        "value": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "sourceIndex": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "digest"],
      "properties": {
        "path": { "const": "registry/index.json" },
        "digest": { "$ref": "#/$defs/digest" }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_file_bytes",
        "max_files_per_skill",
        "max_skill_bytes",
        "max_total_bytes"
      ],
      "properties": {
        "max_file_bytes": { "type": "integer", "minimum": 1 },
        "max_files_per_skill": { "type": "integer", "minimum": 1 },
        "max_skill_bytes": { "type": "integer", "minimum": 1 },
        "max_total_bytes": { "type": "integer", "minimum": 1 }
      }
    },
    "manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "bytes", "digest"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "bytes": { "type": "integer", "minimum": 0 },
        "digest": { "$ref": "#/$defs/digest" }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "base_severity",
        "severity",
        "category",
        "path",
        "line",
        "fingerprint",
        "finding_digest",
        "disposition",
        "exception"
      ],
      "properties": {
        "rule_id": { "type": "string", "minLength": 1 },
        "base_severity": { "enum": ["low", "medium", "high", "critical"] },
        "severity": { "enum": ["low", "medium", "high", "critical"] },
        "category": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "line": { "type": "integer", "minimum": 1 },
        "fingerprint": { "type": "string", "pattern": "^[a-f0-9]{16}$" },
        "finding_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "disposition": { "enum": ["active", "accepted"] },
        "exception": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "status", "expires_on", "review_digest"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "status": { "const": "accepted" },
                "expires_on": { "type": "string", "format": "date" },
                "review_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
              }
            }
          ]
        }
      }
    },
    "security": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scanner",
        "policy",
        "provenance",
        "verdict",
        "files_scanned",
        "finding_count",
        "blocking_count",
        "accepted_exception_count",
        "severity_counts",
        "report_digest",
        "findings"
      ],
      "properties": {
        "scanner": {
          "type": "object",
          "required": ["name", "version"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 }
          }
        },
        "policy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "version", "source", "source_digest", "effective_digest", "enabled_rule_count", "severity_override_count", "exception_count", "fail_on"],
          "properties": {
            "id": { "const": "community-default" },
            "version": { "const": "0.1.0" },
            "source": { "const": "packaged" },
            "source_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "effective_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "enabled_rule_count": { "const": 26 },
            "severity_override_count": { "const": 0 },
            "exception_count": { "const": 0 },
            "fail_on": { "const": "high" }
          }
        },
        "provenance": {
          "type": "object",
          "additionalProperties": false,
          "required": ["target_digest", "rule_catalog_digest", "policy_digest", "applied_exception_ids"],
          "properties": {
            "target_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "rule_catalog_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "policy_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "applied_exception_ids": {
              "type": "array",
              "maxItems": 0
            }
          }
        },
        "verdict": { "enum": ["pass", "pass-with-exceptions", "review"] },
        "files_scanned": { "type": "integer", "minimum": 1 },
        "finding_count": { "type": "integer", "minimum": 0 },
        "blocking_count": { "const": 0 },
        "accepted_exception_count": { "const": 0 },
        "severity_counts": {
          "type": "object",
          "required": ["low", "medium", "high", "critical"],
          "properties": {
            "low": { "type": "integer", "minimum": 0 },
            "medium": { "type": "integer", "minimum": 0 },
            "high": { "type": "integer", "minimum": 0 },
            "critical": { "type": "integer", "minimum": 0 }
          }
        },
        "report_digest": { "$ref": "#/$defs/digest" },
        "findings": {
          "type": "array",
          "items": { "$ref": "#/$defs/finding" }
        }
      }
    },
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "role", "bytes", "digest", "content"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "role": { "enum": ["readme", "example", "artifact"] },
        "title": { "type": "string", "minLength": 1 },
        "bytes": { "type": "integer", "minimum": 0 },
        "digest": { "$ref": "#/$defs/digest" },
        "content": { "type": "string" }
      }
    },
    "skill": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "version",
        "status",
        "maturity",
        "risk_level",
        "source_path",
        "manifest",
        "security",
        "file_count",
        "total_bytes",
        "files",
        "digest"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "minLength": 1 },
        "maturity": { "type": "string", "minLength": 1 },
        "risk_level": { "enum": ["low", "medium", "high"] },
        "source_path": { "type": "string", "minLength": 1 },
        "manifest": { "$ref": "#/$defs/manifest" },
        "security": { "$ref": "#/$defs/security" },
        "file_count": { "type": "integer", "minimum": 1 },
        "total_bytes": { "type": "integer", "minimum": 0 },
        "files": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/file" }
        },
        "digest": { "$ref": "#/$defs/digest" }
      }
    }
  }
}
