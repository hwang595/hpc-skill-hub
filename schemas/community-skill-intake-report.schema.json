{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hpc-skill-hub.org/schemas/community-skill-intake-report.schema.json",
  "title": "HPC Skill Hub Quarantined Community Intake Report",
  "type": "object",
  "required": ["$schema", "schema_version", "engine", "source", "limits", "quarantine", "inventory", "boundary_findings", "security_report", "summary"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "const": "https://hpc-skill-hub.org/schemas/community-skill-intake-report.schema.json"
    },
    "schema_version": {"const": "0.1.0"},
    "engine": {
      "type": "object",
      "required": ["name", "version"],
      "additionalProperties": false,
      "properties": {
        "name": {"const": "hpc-skill-community-intake"},
        "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"}
      }
    },
    "source": {
      "type": "object",
      "required": ["label", "type", "bytes", "sha256", "digest_scope"],
      "additionalProperties": false,
      "properties": {
        "label": {"type": "string", "minLength": 1},
        "type": {"enum": ["directory", "zip", "tar", "symlink"]},
        "bytes": {"type": "integer", "minimum": 0},
        "sha256": {
          "oneOf": [
            {"type": "null"},
            {"type": "string", "pattern": "^[a-f0-9]{64}$"}
          ]
        },
        "digest_scope": {"enum": ["archive-bytes", "bounded-tree", "symlink-target", "unavailable"]}
      }
    },
    "limits": {
      "type": "object",
      "required": ["max_archive_bytes", "max_entries", "max_files", "max_file_bytes", "max_total_bytes", "max_compression_ratio", "max_path_depth", "max_path_bytes"],
      "additionalProperties": false,
      "properties": {
        "max_archive_bytes": {"type": "integer", "minimum": 1},
        "max_entries": {"type": "integer", "minimum": 1},
        "max_files": {"type": "integer", "minimum": 1},
        "max_file_bytes": {"type": "integer", "minimum": 1},
        "max_total_bytes": {"type": "integer", "minimum": 1},
        "max_compression_ratio": {"type": "integer", "minimum": 1},
        "max_path_depth": {"type": "integer", "minimum": 1},
        "max_path_bytes": {"type": "integer", "minimum": 1}
      }
    },
    "quarantine": {
      "type": "object",
      "required": ["strategy", "outside_source", "cleaned", "execution_performed", "instruction_content_returned"],
      "additionalProperties": false,
      "properties": {
        "strategy": {"const": "temporary-copy"},
        "outside_source": {"const": true},
        "cleaned": {"const": true},
        "execution_performed": {"const": false},
        "instruction_content_returned": {"const": false}
      }
    },
    "inventory": {
      "type": "object",
      "required": ["complete", "entry_count", "file_count", "total_bytes", "content_digest", "files"],
      "additionalProperties": false,
      "properties": {
        "complete": {"type": "boolean"},
        "entry_count": {"type": "integer", "minimum": 0},
        "file_count": {"type": "integer", "minimum": 0},
        "total_bytes": {"type": "integer", "minimum": 0},
        "content_digest": {
          "oneOf": [
            {"type": "null"},
            {"type": "string", "pattern": "^[a-f0-9]{64}$"}
          ]
        },
        "files": {
          "type": "array",
          "items": {"$ref": "#/$defs/file"}
        }
      }
    },
    "boundary_findings": {
      "type": "array",
      "items": {"$ref": "#/$defs/boundary_finding"}
    },
    "security_report": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "https://hpc-skill-hub.org/schemas/skill-security-report.schema.json"}
      ]
    },
    "summary": {
      "type": "object",
      "required": ["status", "boundary_finding_count", "security_verdict", "eligible_for_human_review", "context_loading_allowed"],
      "additionalProperties": false,
      "properties": {
        "status": {"enum": ["ready-for-review", "review-required", "blocked"]},
        "boundary_finding_count": {"type": "integer", "minimum": 0},
        "security_verdict": {
          "oneOf": [
            {"type": "null"},
            {"enum": ["pass", "pass-with-exceptions", "review", "block"]}
          ]
        },
        "eligible_for_human_review": {"type": "boolean"},
        "context_loading_allowed": {"const": false}
      }
    }
  },
  "$defs": {
    "file": {
      "type": "object",
      "required": ["path", "type", "bytes", "sha256", "content_type"],
      "additionalProperties": false,
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "type": {"enum": ["file", "symlink", "special"]},
        "bytes": {"type": "integer", "minimum": 0},
        "sha256": {
          "oneOf": [
            {"type": "null"},
            {"type": "string", "pattern": "^[a-f0-9]{64}$"}
          ]
        },
        "content_type": {"enum": ["text", "rejected", "unread"]}
      }
    },
    "boundary_finding": {
      "type": "object",
      "required": ["id", "severity", "path", "message", "remediation"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "pattern": "^intake\\.[a-z][a-z0-9-]*$"},
        "severity": {"const": "high"},
        "path": {"type": "string", "minLength": 1},
        "message": {"type": "string", "minLength": 1},
        "remediation": {"type": "string", "minLength": 1}
      }
    }
  }
}
