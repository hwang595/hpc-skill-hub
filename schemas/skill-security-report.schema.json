{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hpc-skill-hub.org/schemas/skill-security-report.schema.json",
  "title": "HPC Skill Security Report",
  "type": "object",
  "required": ["$schema", "schema_version", "scanner", "target", "policy", "execution", "provenance", "summary", "findings"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "const": "https://hpc-skill-hub.org/schemas/skill-security-report.schema.json"
    },
    "schema_version": {
      "const": "0.2.0"
    },
    "scanner": {
      "type": "object",
      "required": ["name", "version"],
      "additionalProperties": false,
      "properties": {
        "name": {"const": "hpc-skill-security"},
        "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"}
      }
    },
    "target": {"type": "string", "minLength": 1},
    "policy": {
      "type": "object",
      "required": ["id", "version", "source", "source_digest", "effective_digest", "enabled_rule_count", "severity_override_count", "exception_count", "fail_on"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "source": {"enum": ["packaged", "external"]},
        "source_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "effective_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "enabled_rule_count": {"type": "integer", "minimum": 1},
        "severity_override_count": {"type": "integer", "minimum": 0},
        "exception_count": {"type": "integer", "minimum": 0},
        "fail_on": {"enum": ["low", "medium", "high", "critical"]}
      }
    },
    "execution": {
      "type": "object",
      "required": ["exit_on"],
      "additionalProperties": false,
      "properties": {
        "exit_on": {"enum": ["none", "low", "medium", "high", "critical"]}
      }
    },
    "provenance": {
      "type": "object",
      "required": ["target_digest", "rule_catalog_digest", "policy_digest", "applied_exception_ids"],
      "additionalProperties": false,
      "properties": {
        "target_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "rule_catalog_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "policy_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "applied_exception_ids": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["verdict", "files_scanned", "finding_count", "blocking_count", "accepted_exception_count", "severity_counts"],
      "additionalProperties": false,
      "properties": {
        "verdict": {"enum": ["pass", "pass-with-exceptions", "review", "block"]},
        "files_scanned": {"type": "integer", "minimum": 0},
        "finding_count": {"type": "integer", "minimum": 0},
        "blocking_count": {"type": "integer", "minimum": 0},
        "accepted_exception_count": {"type": "integer", "minimum": 0},
        "severity_counts": {
          "type": "object",
          "required": ["low", "medium", "high", "critical"],
          "additionalProperties": false,
          "properties": {
            "low": {"type": "integer", "minimum": 0},
            "medium": {"type": "integer", "minimum": 0},
            "high": {"type": "integer", "minimum": 0},
            "critical": {"type": "integer", "minimum": 0}
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {"$ref": "#/$defs/finding"}
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "required": ["rule_id", "base_severity", "severity", "category", "path", "line", "message", "remediation", "fingerprint", "finding_digest", "disposition", "exception", "skill_id"],
      "additionalProperties": false,
      "properties": {
        "rule_id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*(?:\\.[a-z][a-z0-9-]*)+$"},
        "base_severity": {"enum": ["low", "medium", "high", "critical"]},
        "severity": {"enum": ["low", "medium", "high", "critical"]},
        "category": {"type": "string", "minLength": 1},
        "path": {"type": "string", "minLength": 1},
        "line": {"type": "integer", "minimum": 1},
        "message": {"type": "string", "minLength": 1},
        "remediation": {"type": "string", "minLength": 1},
        "fingerprint": {"type": "string", "pattern": "^[a-f0-9]{16}$"},
        "finding_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "disposition": {"enum": ["active", "accepted"]},
        "exception": {
          "oneOf": [
            {"type": "null"},
            {
              "type": "object",
              "required": ["id", "status", "expires_on", "review_digest"],
              "additionalProperties": false,
              "properties": {
                "id": {"type": "string", "minLength": 1},
                "status": {"const": "accepted"},
                "expires_on": {"type": "string", "format": "date"},
                "review_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
              }
            }
          ]
        },
        "skill_id": {"type": ["string", "null"]}
      }
    }
  }
}
