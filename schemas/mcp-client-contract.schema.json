{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hpc-skill-hub.org/schemas/mcp-client-contract.schema.json",
  "title": "HPC Skill Hub MCP Client Contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schema_version", "server", "providers"],
  "properties": {
    "$schema": { "const": "../schemas/mcp-client-contract.schema.json" },
    "schema_version": { "const": "0.1.0" },
    "server": { "$ref": "#/$defs/server" },
    "providers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["codex", "claude-code"],
      "properties": {
        "codex": {
          "allOf": [
            { "$ref": "#/$defs/provider" },
            {
              "properties": {
                "config_format": { "const": "toml" },
                "user_config_path": { "const": "~/.codex/config.toml" },
                "project_config_path": { "const": ".codex/config.toml" },
                "example_path": { "const": "integrations/codex.config.toml" },
                "add_command": { "const": "codex mcp add hpc-skill-hub -- hpc-skill-mcp" },
                "verify_commands": {
                  "const": [
                    "codex mcp get hpc-skill-hub",
                    "codex mcp list"
                  ]
                },
                "documentation_url": { "const": "https://developers.openai.com/codex/mcp/" }
              }
            }
          ]
        },
        "claude-code": {
          "allOf": [
            { "$ref": "#/$defs/provider" },
            {
              "properties": {
                "config_format": { "const": "json" },
                "user_config_path": { "const": "~/.claude.json" },
                "project_config_path": { "const": ".mcp.json" },
                "example_path": { "const": "integrations/claude-code.mcp.json" },
                "add_command": { "const": "claude mcp add --transport stdio --scope project hpc-skill-hub -- hpc-skill-mcp" },
                "verify_commands": {
                  "const": [
                    "claude mcp get hpc-skill-hub",
                    "claude mcp list"
                  ]
                },
                "documentation_url": { "const": "https://code.claude.com/docs/en/mcp" }
              }
            }
          ]
        }
      }
    }
  },
  "$defs": {
    "python": {
      "type": "object",
      "additionalProperties": false,
      "required": ["core_minimum", "mcp_minimum"],
      "properties": {
        "core_minimum": { "const": "3.9" },
        "mcp_minimum": { "const": "3.10" }
      }
    },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "uri_template", "mime_type"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "uri_template": { "type": "string", "minLength": 1 },
        "mime_type": { "const": "application/json" }
      }
    },
    "safetyBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "executes_commands",
        "writes_files",
        "uses_network",
        "submits_jobs",
        "returns_unreviewed_community_content",
        "accepts_private_site_policy",
        "uses_mcp_logging",
        "logs_sensitive_arguments"
      ],
      "properties": {
        "executes_commands": { "const": false },
        "writes_files": { "const": false },
        "uses_network": { "const": false },
        "submits_jobs": { "const": false },
        "returns_unreviewed_community_content": { "const": false },
        "accepts_private_site_policy": { "const": false },
        "uses_mcp_logging": { "const": false },
        "logs_sensitive_arguments": { "const": false }
      }
    },
    "server": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "transport",
        "command",
        "args",
        "env",
        "package_extra",
        "registry_schema_version",
        "python",
        "read_only",
        "tools",
        "tool_arguments",
        "resources",
        "safety_boundary"
      ],
      "properties": {
        "id": { "const": "hpc-skill-hub" },
        "name": { "const": "HPC Skill Hub" },
        "transport": { "const": "stdio" },
        "command": { "const": "hpc-skill-mcp" },
        "args": { "type": "array", "maxItems": 0 },
        "env": { "type": "object", "maxProperties": 0 },
        "package_extra": { "const": "hpc-skill-hub[mcp]" },
        "registry_schema_version": { "const": "0.2.0" },
        "python": { "$ref": "#/$defs/python" },
        "read_only": { "const": true },
        "tools": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "tool_arguments": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "resources": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/resource" }
        },
        "safety_boundary": { "$ref": "#/$defs/safetyBoundary" }
      }
    },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "config_format",
        "user_config_path",
        "project_config_path",
        "example_path",
        "add_command",
        "verify_commands",
        "documentation_url"
      ],
      "properties": {
        "config_format": { "enum": ["json", "toml"] },
        "user_config_path": { "type": "string", "minLength": 1 },
        "project_config_path": { "type": "string", "minLength": 1 },
        "example_path": { "type": "string", "minLength": 1 },
        "add_command": { "type": "string", "minLength": 1 },
        "verify_commands": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "documentation_url": { "type": "string", "format": "uri" }
      }
    }
  }
}
