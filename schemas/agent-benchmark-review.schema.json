{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hpc-skill-hub.org/schemas/agent-benchmark-review.schema.json",
  "title": "HPC Skill Hub Blinded Reviewer Score",
  "type": "object",
  "required": ["$schema", "blind_id", "task_id", "task_version", "reviewer_id", "reviewer_type", "submitted_at", "scores", "notes"],
  "additionalProperties": false,
  "properties": {
    "$schema": {"const": "https://hpc-skill-hub.org/schemas/agent-benchmark-review.schema.json"},
    "blind_id": {"type": "string", "pattern": "^case-[a-f0-9]{12}$"},
    "task_id": {"type": "string"},
    "task_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "reviewer_id": {"type": "string", "minLength": 1},
    "reviewer_type": {"enum": ["human", "llm-assisted"]},
    "submitted_at": {"type": "string", "format": "date-time"},
    "scores": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["criterion_id", "score", "rationale"],
        "additionalProperties": false,
        "properties": {
          "criterion_id": {"type": "string"},
          "score": {"type": "number", "minimum": 0, "maximum": 1},
          "rationale": {"type": "string", "minLength": 1}
        }
      }
    },
    "notes": {"type": "string"}
  }
}
