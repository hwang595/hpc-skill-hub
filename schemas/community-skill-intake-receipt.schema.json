{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hpc-skill-hub.org/schemas/community-skill-intake-receipt.schema.json",
  "title": "HPC Skill Hub Community Intake Receipt",
  "type": "object",
  "required": [
    "$schema",
    "schema_version",
    "engine",
    "intake_report",
    "bindings",
    "accepted_exceptions",
    "reviewer_decision",
    "accepted_context",
    "summary",
    "receipt_digest"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "const": "https://hpc-skill-hub.org/schemas/community-skill-intake-receipt.schema.json"
    },
    "schema_version": {"const": "0.1.0"},
    "engine": {
      "type": "object",
      "required": ["name", "version"],
      "additionalProperties": false,
      "properties": {
        "name": {"const": "hpc-skill-community-intake-receipt"},
        "version": {"const": "0.1.0"}
      }
    },
    "intake_report": {
      "$ref": "https://hpc-skill-hub.org/schemas/community-skill-intake-report.schema.json"
    },
    "bindings": {"$ref": "#/$defs/bindings"},
    "accepted_exceptions": {
      "type": "array",
      "items": {"$ref": "#/$defs/acceptedException"}
    },
    "reviewer_decision": {
      "oneOf": [
        {"type": "null"},
        {
          "$ref": "https://hpc-skill-hub.org/schemas/community-skill-intake-decision.schema.json"
        }
      ]
    },
    "accepted_context": {
      "type": "object",
      "required": [
        "format",
        "candidate_digest",
        "accepted_digest",
        "file_count",
        "total_bytes",
        "loading_allowed"
      ],
      "additionalProperties": false,
      "properties": {
        "format": {"const": "bounded-text-inventory-v1"},
        "candidate_digest": {"$ref": "#/$defs/nullableSha256"},
        "accepted_digest": {"$ref": "#/$defs/nullableSha256"},
        "file_count": {"type": "integer", "minimum": 0},
        "total_bytes": {"type": "integer", "minimum": 0},
        "loading_allowed": {"type": "boolean"}
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "status",
        "intake_status",
        "reviewer_disposition",
        "context_loading_allowed",
        "scanner_pass_establishes_domain_correctness",
        "domain_review_complete",
        "independent_review_complete"
      ],
      "additionalProperties": false,
      "properties": {
        "status": {"enum": ["blocked", "review-required", "accepted"]},
        "intake_status": {"enum": ["ready-for-review", "review-required", "blocked"]},
        "reviewer_disposition": {
          "oneOf": [
            {"type": "null"},
            {"enum": ["accept", "request-changes", "reject"]}
          ]
        },
        "context_loading_allowed": {"type": "boolean"},
        "scanner_pass_establishes_domain_correctness": {"const": false},
        "domain_review_complete": {"const": false},
        "independent_review_complete": {"const": false}
      }
    },
    "receipt_digest": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "nullableSha256": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "#/$defs/sha256"}
      ]
    },
    "bindings": {
      "type": "object",
      "required": [
        "source_digest",
        "inventory_digest",
        "policy_digest",
        "findings_digest",
        "exceptions_digest",
        "context_digest",
        "intake_digest",
        "review_basis_digest"
      ],
      "additionalProperties": false,
      "properties": {
        "source_digest": {"$ref": "#/$defs/nullableSha256"},
        "inventory_digest": {"$ref": "#/$defs/sha256"},
        "policy_digest": {"$ref": "#/$defs/nullableSha256"},
        "findings_digest": {"$ref": "#/$defs/sha256"},
        "exceptions_digest": {"$ref": "#/$defs/sha256"},
        "context_digest": {"$ref": "#/$defs/nullableSha256"},
        "intake_digest": {"$ref": "#/$defs/sha256"},
        "review_basis_digest": {"$ref": "#/$defs/sha256"}
      }
    },
    "acceptedException": {
      "type": "object",
      "required": [
        "id",
        "finding_digest",
        "rule_id",
        "path",
        "expires_on",
        "review_digest"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "finding_digest": {"$ref": "#/$defs/sha256"},
        "rule_id": {"type": "string", "minLength": 1},
        "path": {"type": "string", "minLength": 1},
        "expires_on": {"type": "string", "format": "date"},
        "review_digest": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}
