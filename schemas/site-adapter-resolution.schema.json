{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hpc-skill-hub.org/schemas/site-adapter-resolution.schema.json",
  "title": "HPC Skill Hub Site Adapter Resolution",
  "type": "object",
  "required": ["$schema", "schema_version", "resolution_status", "skill", "adapter", "compatibility", "public_policy", "override", "review"],
  "additionalProperties": false,
  "properties": {
    "$schema": {"const": "https://hpc-skill-hub.org/schemas/site-adapter-resolution.schema.json"},
    "schema_version": {"const": "0.1.0"},
    "resolution_status": {"enum": ["mapped", "compatible-unmapped", "incompatible"]},
    "skill": {
      "type": "object",
      "required": ["id", "version", "status", "maturity", "risk_level", "schedulers", "readme", "examples"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string"},
        "version": {"type": "string"},
        "status": {"type": "string"},
        "maturity": {"type": "string"},
        "risk_level": {"enum": ["low", "medium", "high"]},
        "schedulers": {"type": "array", "items": {"type": "string"}},
        "readme": {"type": "string"},
        "examples": {"type": "array", "items": {"type": "object"}}
      }
    },
    "adapter": {
      "type": "object",
      "required": ["id", "status", "institution_type", "scheduler", "readme"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string"},
        "status": {"type": "string"},
        "institution_type": {"type": "string"},
        "scheduler": {"type": ["string", "null"]},
        "readme": {"type": "string"}
      }
    },
    "compatibility": {
      "type": "object",
      "required": ["scheduler_compatible", "explicit_override"],
      "additionalProperties": false,
      "properties": {
        "scheduler_compatible": {"type": "boolean"},
        "explicit_override": {"type": "boolean"}
      }
    },
    "public_policy": {"type": "object"},
    "override": {"type": ["object", "null"]},
    "review": {
      "type": "object",
      "required": ["required", "reasons", "rules"],
      "additionalProperties": false,
      "properties": {
        "required": {"const": true},
        "reasons": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "rules": {"type": "array", "minItems": 1, "items": {"type": "string"}}
      }
    }
  }
}
