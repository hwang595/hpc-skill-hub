{
  "$schema": "../../schemas/skill.schema.json",
  "id": "slurm-submit-job",
  "name": "Slurm Submit Job",
  "version": "0.2.0",
  "status": "draft",
  "summary": "Generate safe Slurm batch scripts for common HPC job shapes.",
  "description": "This skill helps users create Slurm sbatch scripts for CPU, GPU, MPI, and array workloads with conservative defaults and clear placeholders.",
  "categories": ["scheduler"],
  "tags": ["slurm", "sbatch", "cpu", "gpu", "mpi", "array"],
  "maintainers": [
    {
      "name": "HPC Skill Hub Maintainers"
    }
  ],
  "license": "MIT",
  "maturity": "seed",
  "risk_level": "medium",
  "schedulers": ["slurm"],
  "tools": [
    {
      "name": "sbatch",
      "required": true
    },
    {
      "name": "srun",
      "required": false
    }
  ],
  "inputs": [
    {
      "name": "account",
      "type": "string",
      "required": false,
      "description": "Site-specific allocation or account name."
    },
    {
      "name": "partition",
      "type": "string",
      "required": false,
      "description": "Target Slurm partition or queue."
    },
    {
      "name": "resources",
      "type": "object",
      "required": true,
      "description": "Requested nodes, tasks, CPUs, memory, GPUs, and wall time."
    }
  ],
  "outputs": [
    {
      "name": "sbatch_script",
      "description": "A Slurm batch script that can be adapted and submitted."
    },
    {
      "name": "job_id",
      "description": "The job id printed by sbatch after submission."
    }
  ],
  "artifacts": [
    "README.md",
    "examples/cpu.sbatch",
    "examples/mpi.sbatch",
    "examples/gpu.sbatch",
    "examples/array.sbatch",
    "examples/review-sbatch.sh"
  ],
  "examples": [
    {
      "title": "CPU batch job",
      "path": "examples/cpu.sbatch"
    },
    {
      "title": "MPI batch job",
      "path": "examples/mpi.sbatch"
    },
    {
      "title": "GPU batch job",
      "path": "examples/gpu.sbatch"
    },
    {
      "title": "Array batch job",
      "path": "examples/array.sbatch"
    },
    {
      "title": "Review a batch script without submitting",
      "path": "examples/review-sbatch.sh"
    }
  ],
  "tests": [
    {
      "type": "static",
      "command": "python3 tools/validate_skills.py --skill slurm-submit-job",
      "description": "Validate the manifest and referenced scripts."
    },
    {
      "type": "manual",
      "description": "Run sbatch --test-only if supported by the local Slurm version, then submit with a short wall time on a test partition."
    }
  ],
  "references": [
    {
      "title": "Slurm sbatch documentation",
      "url": "https://slurm.schedmd.com/sbatch.html"
    },
    {
      "title": "Slurm srun documentation",
      "url": "https://slurm.schedmd.com/srun.html"
    },
    {
      "title": "Slurm Generic Resource scheduling",
      "url": "https://slurm.schedmd.com/gres.html"
    }
  ]
}
