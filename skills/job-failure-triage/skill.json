{
  "$schema": "../../schemas/skill.schema.json",
  "id": "job-failure-triage",
  "name": "Job Failure Triage",
  "version": "0.2.0",
  "status": "draft",
  "summary": "Diagnose common HPC job failures from scheduler and log evidence.",
  "description": "This skill provides a first-pass checklist for failed jobs, including out-of-memory events, time limits, missing modules, permission errors, and node failures.",
  "categories": ["debugging", "scheduler"],
  "tags": ["slurm", "failure", "oom", "timeout", "logs", "triage"],
  "maintainers": [
    {
      "name": "HPC Skill Hub Maintainers"
    }
  ],
  "license": "MIT",
  "maturity": "seed",
  "risk_level": "low",
  "schedulers": ["slurm"],
  "tools": [
    {
      "name": "sacct",
      "required": false
    },
    {
      "name": "scontrol",
      "required": false
    },
    {
      "name": "grep",
      "required": true
    },
    {
      "name": "tail",
      "required": true
    }
  ],
  "inputs": [
    {
      "name": "job_id",
      "type": "string",
      "required": false,
      "description": "Scheduler job id."
    },
    {
      "name": "log_file",
      "type": "path",
      "required": true,
      "description": "Output or error log generated by the job."
    }
  ],
  "outputs": [
    {
      "name": "triage_report",
      "description": "Evidence and likely next actions for the failed job."
    }
  ],
  "artifacts": [
    "README.md",
    "examples/triage-slurm-job.sh",
    "examples/triage-evidence-checklist.md"
  ],
  "examples": [
    {
      "title": "Triage a failed Slurm job",
      "path": "examples/triage-slurm-job.sh"
    },
    {
      "title": "Record scheduler and application evidence",
      "path": "examples/triage-evidence-checklist.md"
    }
  ],
  "tests": [
    {
      "type": "static",
      "command": "python3 tools/validate_skills.py --skill job-failure-triage",
      "description": "Validate the manifest and example script."
    },
    {
      "type": "manual",
      "description": "Run against a failed test job and confirm the report highlights scheduler state and log clues."
    }
  ],
  "references": [
    {
      "title": "Slurm job state codes",
      "url": "https://slurm.schedmd.com/job_state_codes.html"
    },
    {
      "title": "Slurm sacct documentation",
      "url": "https://slurm.schedmd.com/sacct.html"
    },
    {
      "title": "Slurm job exit codes",
      "url": "https://slurm.schedmd.com/job_exit_code.html"
    }
  ]
}
