{
  "$schema": "../../schemas/benchmark.schema.json",
  "id": "slurm-submit-static",
  "name": "Slurm submit example syntax",
  "version": "0.2.0",
  "status": "draft",
  "mode": "static",
  "risk_level": "low",
  "skill_ids": ["slurm-submit-job"],
  "summary": "Check that Slurm submit examples remain shell-parseable and keep placeholders visible.",
  "fixtures": [],
  "commands": [
    {
      "label": "CPU sbatch syntax",
      "argv": ["bash", "-n", "skills/slurm-submit-job/examples/cpu.sbatch"],
      "expect_returncode": 0
    },
    {
      "label": "MPI sbatch syntax",
      "argv": ["bash", "-n", "skills/slurm-submit-job/examples/mpi.sbatch"],
      "expect_returncode": 0
    },
    {
      "label": "GPU sbatch syntax",
      "argv": ["bash", "-n", "skills/slurm-submit-job/examples/gpu.sbatch"],
      "expect_returncode": 0
    },
    {
      "label": "Array sbatch syntax",
      "argv": ["bash", "-n", "skills/slurm-submit-job/examples/array.sbatch"],
      "expect_returncode": 0
    },
    {
      "label": "Static reviewer blocks unresolved placeholders",
      "argv": ["bash", "skills/slurm-submit-job/examples/review-sbatch.sh", "skills/slurm-submit-job/examples/cpu.sbatch"],
      "expect_returncode": 3
    }
  ],
  "checks": [
    {
      "label": "CPU example keeps site placeholders",
      "type": "contains_all",
      "path": "skills/slurm-submit-job/examples/cpu.sbatch",
      "patterns": ["<account>", "<partition>", "Replace this with the real workload"]
    },
    {
      "label": "Submission guidance keeps review and submit separate",
      "type": "contains_all",
      "path": "skills/slurm-submit-job/README.md",
      "patterns": ["static reviewer", "explicit user approval", "total request", "Do not publish private"]
    }
  ],
  "expected_outcomes": [
    "Examples are parseable as shell scripts without submitting jobs.",
    "Scheduler account and partition remain placeholders until a site or user supplies values."
  ]
}
