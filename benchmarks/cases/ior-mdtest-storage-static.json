{
  "$schema": "../../schemas/benchmark.schema.json",
  "id": "ior-mdtest-storage-static",
  "name": "IOR and MDTest storage smoke static checks",
  "version": "0.2.0",
  "status": "draft",
  "mode": "static",
  "risk_level": "low",
  "skill_ids": ["ior-mdtest-storage-smoke"],
  "summary": "Check that storage smoke examples remain parseable and policy-gated.",
  "fixtures": [
    {
      "path": "benchmarks/fixtures/storage/ior-mdtest-run/run-metadata.txt",
      "description": "Synthetic metadata for a bounded four-task storage smoke run."
    },
    {
      "path": "benchmarks/fixtures/storage/ior-mdtest-run/commands.txt",
      "description": "Synthetic reviewed IOR and MDTest command capture."
    },
    {
      "path": "benchmarks/fixtures/storage/ior-mdtest-run/ior.out",
      "description": "Synthetic IOR summary output."
    },
    {
      "path": "benchmarks/fixtures/storage/ior-mdtest-run/mdtest.out",
      "description": "Synthetic MDTest summary output."
    }
  ],
  "commands": [
    {
      "label": "Storage preflight syntax",
      "argv": ["bash", "-n", "skills/ior-mdtest-storage-smoke/examples/storage-smoke-preflight.sh"],
      "expect_returncode": 0
    },
    {
      "label": "Storage smoke sbatch syntax",
      "argv": ["bash", "-n", "skills/ior-mdtest-storage-smoke/examples/ior-mdtest-smoke.sbatch"],
      "expect_returncode": 0
    },
    {
      "label": "Storage cleanup syntax",
      "argv": ["bash", "-n", "skills/ior-mdtest-storage-smoke/examples/cleanup-run.sh"],
      "expect_returncode": 0
    },
    {
      "label": "Storage preflight does not create an unapproved root",
      "argv": ["bash", "skills/ior-mdtest-storage-smoke/examples/storage-smoke-preflight.sh", "--paths-only", "benchmarks/fixtures/storage/planned-ior-root"],
      "expect_returncode": 0
    },
    {
      "label": "Storage summary accepts a complete marked fixture",
      "argv": ["python3", "skills/ior-mdtest-storage-smoke/examples/summarize-results.py", "benchmarks/fixtures/storage/ior-mdtest-run"],
      "expect_returncode": 0
    },
    {
      "label": "Storage cleanup remains explicit opt-in",
      "argv": ["bash", "skills/ior-mdtest-storage-smoke/examples/cleanup-run.sh", "benchmarks/fixtures/storage/ior-mdtest-run"],
      "expect_returncode": 2
    }
  ],
  "checks": [
    {
      "label": "Policy checklist warns against broad performance claims",
      "type": "contains_all",
      "path": "skills/ior-mdtest-storage-smoke/examples/site-policy-checklist.md",
      "patterns": ["benchmark-approved", "not as a site-wide performance"]
    },
    {
      "label": "Plan-only mode exits before creating run artifacts",
      "type": "contains_all",
      "path": "skills/ior-mdtest-storage-smoke/examples/ior-mdtest-smoke.sbatch",
      "patterns": ["Plan-only mode. No directories or files were created.", "CONFIRM_STORAGE_POLICY", "run directory already exists"]
    },
    {
      "label": "Storage smoke enforces bounded parameters",
      "type": "contains_all",
      "path": "skills/ior-mdtest-storage-smoke/examples/ior-mdtest-smoke.sbatch",
      "patterns": ["SLURM_NTASKS", "IOR_BLOCK_SIZE", "IOR_TRANSFER_SIZE", "MDTEST_ITEMS", "smoke-test cap"]
    }
  ],
  "expected_outcomes": [
    "The skill should require local policy review before running storage benchmarks.",
    "The skill should frame results as support triage evidence, not broad site performance claims."
  ]
}
